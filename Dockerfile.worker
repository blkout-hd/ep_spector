# ─────────────────────────────────────────────
# SPECTOR Agent Worker
# GPU-aware LangGraph pipeline executor
# Falls back gracefully to CPU if no GPU
# ─────────────────────────────────────────────
FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgomp1 \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Builder ──────────────────────────────────
FROM base AS builder
WORKDIR /build
COPY pyproject.toml .

# Install CPU-tier base; GPU extras added via bootstrap.py at runtime
RUN pip install --upgrade pip && \
    pip install --prefix=/install \
    numpy>=1.24.0 \
    pandas>=2.0.0 \
    PyMuPDF>=1.23.0 \
    pdfminer.six>=20221105 \
    pdfplumber>=0.10.0 \
    spacy>=3.6.0 \
    gliner>=0.2.0 \
    sentence-transformers>=2.2.0 \
    umap-learn>=0.5.4 \
    openTSNE>=1.0.0 \
    hdbscan>=0.8.33 \
    scikit-learn>=1.3.0 \
    qdrant-client>=1.6.0 \
    neo4j>=5.0.0 \
    redis>=5.0.0 \
    pymongo>=4.5.0 \
    duckdb>=0.9.0 \
    langgraph>=0.2.0 \
    langchain>=0.1.0 \
    aiohttp>=3.9.0 \
    python-dotenv>=1.0.0 \
    rich>=13.0.0 \
    tqdm>=4.65.0

# ── Runtime ──────────────────────────────────
FROM base AS runtime
COPY --from=builder /install /usr/local

RUN groupadd --gid 1003 worker && \
    useradd --uid 1003 --gid worker --shell /bin/bash --create-home worker

WORKDIR /app
COPY src/python/ /app/
COPY scripts/ /app/scripts/

RUN chown -R worker:worker /app
USER worker

# Runtime capability probe — installs GPU tier if CUDA detected
CMD ["sh", "-c", "python scripts/bootstrap.py && python -m pipeline.runner"]
